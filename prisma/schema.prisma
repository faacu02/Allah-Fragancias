generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  collection String
  price      Float
  stock      Int
  status     String   @default("OK") // "OK" | "LOW"
  image      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
