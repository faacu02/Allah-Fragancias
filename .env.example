# Server (required)
DATABASE_URL=postgresql://user:password@localhost:5432/allah-fragancias
JWT_SECRET=your-secret-key-at-least-32-characters-long

# Cloudinary (required for product images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMTP (required for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Bank details (required for checkout transfer info)
BANK_NAME=Banco Ejemplo
ACCOUNT_TYPE=Caja de Ahorro
ACCOUNT_NUMBER=00000000000000
ALIAS=alias.ejemplo
CUIT=00-00000000-0
HOLDER_NAME=Titular

# Upstash Redis (optional - rate limiting in production)
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# App config
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=5490000000000
