# === Base de datos ===
DATABASE_URL="postgresql://user:password@host:5432/allah_fragancias?schema=public"

# === Cloudinary (imágenes) ===
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# === Autenticación ===
JWT_SECRET="genera_un_secreto_fuerte_con_openssl_rand_hex_32"

# === SMTP (correos) ===
SMTP_USER="tucorreo@gmail.com"
SMTP_PASS="tu_app_password_de_gmail"

# === Datos bancarios (transferencia) ===
BANK_NAME="Nombre del banco"
ACCOUNT_TYPE="Cuenta Corriente"
ACCOUNT_NUMBER="123456789"
ALIAS="ALIAS.CBU"
CUIT="20-12345678-9"
HOLDER_NAME="Nombre del titular"

# === Rate Limiting (Upstash Redis) ===
# Crear base gratis en https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL="https://tu-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="tu_token"

# === WhatsApp (número del vendedor, con código de país sin +) ===
NEXT_PUBLIC_WHATSAPP_NUMBER="5491123456789"

# === URL base (para enlaces en correos) ===
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# === Puerto (local) ===
PORT=3001
